# Copy this to .env and fill in your values

# Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Gmail address you'll send FROM
GMAIL_ADDRESS=you@gmail.com

# Gmail App Password (NOT your regular password)
# How to get one: Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email address to deliver quotes TO (can be same as above)
RECIPIENT_EMAIL=you@gmail.com
